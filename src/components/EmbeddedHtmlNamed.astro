---
interface Props{
    name: string
}

const {name} = Astro.props
---

<section>
    <h4>{name} さんの状況</h4>
    <slot name = 'default'>
        <p>{name} さんは問題ありません</p>
    </slot>
    <h5>詳細内容</h5>
    <slot name = 'detail'>
        <p>特にありません</p>
    </slot>
</section>

<style>
    section{
        border: green 1px dashed;
        margin: 10px;
    }
</style>
